---
import { SideBarMenu } from "@comp/SideBarMenu";
import { UserPermissionsMap } from "@comp/users/Users";

const routes = [
  { name: "Dashboard", path: "/" },
  {
    name: "Materiais",
    path: "/materiais/",
    permissionNeeded: UserPermissionsMap.materials,
  },
  {
    name: "Fornecedores",
    path: "/fornecedores/",
    permissionNeeded: UserPermissionsMap.suppliers,
  },
  {
    name: "Compras",
    path: "/compras/",
    permissionNeeded: UserPermissionsMap.purchases,
  },
  {
    name: "Usuários",
    path: "/usuarios/",
    permissionNeeded: UserPermissionsMap.users,
  },
  {
    name: "Clientes",
    path: "/clientes/",
    permissionNeeded: UserPermissionsMap.customers,
  },
  {
    name: "Orçamentos",
    path: "/orcamentos/",
    permissionNeeded: UserPermissionsMap.quotations,
  },
  {
    name: "Ordens",
    path: "/ordens/",
    permissionNeeded: UserPermissionsMap.orders,
  },
  {
    name: "Pedidos",
    path: "/pedidos/",
    permissionNeeded: UserPermissionsMap.transactions,
  },
  {
    name: "Serviços",
    path: "/servicos/",
    permissionNeeded: UserPermissionsMap.services,
  },
  {
    name: "Financeiro",
    path: "/financeiro/",
    permissionNeeded: UserPermissionsMap.payment,
  },
];
---

<aside
  id="sideBar"
  transition:persist
  class="bg-slate-800 p-4 gap-3 flex md:flex-col navBar md:fixed md:h-full not-md:w-full not-md:overflow-scroll"
>
  <SideBarMenu routes={routes} client:only="preact" />
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const role = localStorage.getItem("apiRole");
      const permissions = localStorage.getItem("apiPermissions");
      if (role == undefined || permissions == undefined) {
        document.location.href = "login/";
      }
    });
  </script>
</aside>
